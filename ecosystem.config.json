{
  "apps": [{
    "name": "CuraBot",
    "script": "server.js",
    "cwd": "/home/admin/CuraBot/CuraBot/CuraBot_new",
    "instances": 1,
    "exec_mode": "fork",
    "watch": false,
    "max_memory_restart": "300M",
    "env": {
      "NODE_ENV": "production",
      "PORT": "3000"
    },
    "error_file": "logs/error.log",
    "out_file": "logs/output.log",
    "log_date_format": "YYYY-MM-DD HH:mm:ss",
    "restart_delay": 3000,
    "max_restarts": 10,
    "min_uptime": "5s"
  }]
}
